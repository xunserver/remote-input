menu "Input Device"

config INPUT_WS_ENABLED
    bool "Enable WebSocket input receiver"
    default y
    select HTTPD_WS_SUPPORT
    select HTTPD_WS_POST_HANDSHAKE_CB_SUPPORT
    help
        Start a WiFi SoftAP and WebSocket endpoint for browser-based
        Input protocol frames.

config INPUT_WIFI_AP_SSID
    string "WebSocket SoftAP SSID"
    default "Input-S3"
    depends on INPUT_WS_ENABLED

config INPUT_WIFI_AP_PASSWORD
    string "WebSocket SoftAP WPA2 password"
    default "input"
    depends on INPUT_WS_ENABLED
    help
        WPA2 password for the SoftAP. Must be at least 8 characters.

config INPUT_WIFI_AP_CHANNEL
    int "WebSocket SoftAP channel"
    range 1 13
    default 6
    depends on INPUT_WS_ENABLED

config INPUT_WS_MAX_CLIENTS
    int "Maximum WebSocket clients"
    range 1 4
    default 1
    depends on INPUT_WS_ENABLED

config INPUT_DISPLAY_ENABLED
    bool "Enable LCD status display"
    default n
    help
        Enable the LVGL status screen for boards that already initialize
        LCD hardware, LVGL tick handling, display flushing, and the LVGL
        timer loop before input_service_init() runs.

        Keep this disabled on builds without a board-level LVGL port.

endmenu
